# Caava Group - Project Management Tool Production Environment

# Database Settings
POSTGRES_USER="caava_admin"
POSTGRES_PASSWORD="caava_password_replace_me"
POSTGRES_DB="caava_db"

# Redis Settings
REDIS_HOST="caava-redis"
REDIS_PORT="6379"

# RabbitMQ Settings
RABBITMQ_HOST="caava-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="caava_mq"
RABBITMQ_PASSWORD="caava_mq_password_replace_me"
RABBITMQ_VHOST="caava_vhost"

# Base URLs (Extremely Important!)
# Set this to your IP or Domain
WEB_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# Proxy Settings
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

# Storage Settings (Minio)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="caava-access-key"
AWS_SECRET_ACCESS_KEY="caava-secret-key-replace-me"
AWS_S3_ENDPOINT_URL="http://caava-minio:9000"
AWS_S3_BUCKET_NAME="uploads"
FILE_SIZE_LIMIT=5242880

# Application Settings
USE_MINIO=1
API_KEY_RATE_LIMIT="60/minute"
