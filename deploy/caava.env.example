# Caava Group - Project Management Tool Production Environment

# Database Settings
POSTGRES_USER="caava_admin"
POSTGRES_PASSWORD="REPLACE_ME_DB_PASSWORD"
POSTGRES_DB="caava_db"

# Redis Settings
REDIS_HOST="plane-redis"
REDIS_PORT="6379"

# RabbitMQ Settings
RABBITMQ_HOST="plane-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="caava_mq"
RABBITMQ_PASSWORD="caava_mq_password_replace_me"
RABBITMQ_VHOST="caava_vhost"

# Base URLs (Extremely Important!)
# Set this to your IP or Domain (e.g., http://10.176.16.100)
WEB_URL=REPLACE_ME_WEB_URL
CORS_ALLOWED_ORIGINS=REPLACE_ME_WEB_URL

# Application Security
SECRET_KEY="REPLACE_ME_SECRET_KEY"

# Proxy Settings
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

# Storage Settings (Minio)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="caava-access-key"
AWS_SECRET_ACCESS_KEY="REPLACE_ME_MINIO_SECRET_KEY"
AWS_S3_ENDPOINT_URL="http://plane-minio:9000"
AWS_S3_BUCKET_NAME="uploads"
FILE_SIZE_LIMIT=5242880

# Application Settings
DEBUG=0
USE_MINIO=1
API_KEY_RATE_LIMIT="60/minute"
GUNICORN_WORKERS=2

# Internal Service URLs (Glue)
REDIS_URL="redis://plane-redis:6379/0"
DATABASE_URL="REPLACE_ME_DATABASE_URL"
API_BASE_URL="http://api:8000"

# Real-time Server (Live)
LIVE_SERVER_SECRET_KEY="REPLACE_ME_LIVE_SECRET_KEY"
LIVE_BASE_URL="http://localhost/live"
LIVE_BASE_PATH="/live"

# SSL Settings
