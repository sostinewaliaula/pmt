# Caava Group - Development Environment Settings
# This file is used by docker-compose.dev.yml

# Database Settings
POSTGRES_USER="caava_dev"
POSTGRES_PASSWORD="caava_dev_password"
POSTGRES_DB="caava_dev_db"

# Redis Settings
REDIS_HOST="plane-redis"
REDIS_PORT="6379"

# RabbitMQ Settings
RABBITMQ_HOST="plane-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="caava_mq"
RABBITMQ_PASSWORD="caava_mq_password"
RABBITMQ_VHOST="caava_vhost"

# Base URLs (Sandbox Ports)
WEB_URL=http://localhost:8091
CORS_ALLOWED_ORIGINS=http://localhost:8091

# Proxy Settings
LISTEN_HTTP_PORT=8091
LISTEN_HTTPS_PORT=4443

# Storage Settings (Minio Dev)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="caava-access-key"
AWS_SECRET_ACCESS_KEY="caava-secret-key"
AWS_S3_ENDPOINT_URL="http://plane-minio:9000"
AWS_S3_BUCKET_NAME="uploads"

# Application Settings
DEBUG=1
USE_MINIO=1

# ==========================================
# LDAP Development Settings (Experimental)
# ==========================================
LDAP_ENABLED=0
LDAP_SERVER_URI="ldap://mock-ldap:389"
LDAP_BIND_DN="cn=admin,dc=caava,dc=dev"
LDAP_BIND_PASSWORD="admin"
LDAP_USER_SEARCH_BASE="ou=users,dc=caava,dc=dev"
LDAP_USER_SEARCH_FILTER="(uid=%(user)s)"
